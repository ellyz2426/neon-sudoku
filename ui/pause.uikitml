<container name="root" display="none" flex-direction="column" align-items="center" padding="16" background-color="#001a1a" border-radius="12" border-width="2" border-color="#ffff00" width="280" gap="8">
  <text font-size="20" color="#ffff00" font-weight="bold" text-align="center">PAUSED</text>
  <text name="lbl-pause-info" font-size="10" color="#888888" text-align="center"> </text>
  <text name="btn-resume" font-size="16" color="#00ff88" background-color="#002211" padding="8" border-radius="6" border-width="1" border-color="#00ff88" text-align="center" width="180" cursor="pointer">RESUME</text>
  <text name="btn-save-quit" font-size="14" color="#ffaa00" background-color="#221100" padding="6" border-radius="6" border-width="1" border-color="#ffaa00" text-align="center" width="180" cursor="pointer">SAVE + QUIT</text>
  <text name="btn-quit" font-size="14" color="#ff4444" background-color="#220000" padding="6" border-radius="6" border-width="1" border-color="#ff4444" text-align="center" width="180" cursor="pointer">QUIT</text>
</container>

<container name="root" display="none" flex-direction="column" align-items="center" padding="16" background-color="#001a1a" border-radius="12" border-width="2" border-color="#00ffff" width="280" gap="8">
  <text font-size="20" color="#00ffff" font-weight="bold" text-align="center">DIFFICULTY</text>
  <text name="btn-easy" font-size="16" color="#00ff88" background-color="#002211" padding="8" border-radius="6" border-width="1" border-color="#00ff88" text-align="center" width="200" cursor="pointer">Easy</text>
  <text name="btn-medium" font-size="16" color="#ffaa00" background-color="#221100" padding="8" border-radius="6" border-width="1" border-color="#ffaa00" text-align="center" width="200" cursor="pointer">Medium</text>
  <text name="btn-hard" font-size="16" color="#ff4444" background-color="#220000" padding="8" border-radius="6" border-width="1" border-color="#ff4444" text-align="center" width="200" cursor="pointer">Hard</text>
  <text name="btn-expert" font-size="16" color="#ff00ff" background-color="#220022" padding="8" border-radius="6" border-width="1" border-color="#ff00ff" text-align="center" width="200" cursor="pointer">Expert</text>
  <text name="btn-back" font-size="12" color="#888888" background-color="#111111" padding="4" border-radius="4" text-align="center" width="120" cursor="pointer" margin-top="4">BACK</text>
</container>
